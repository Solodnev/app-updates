        <item>
            <title>Version 0.7.3</title>
            <sparkle:version>19</sparkle:version>
            <sparkle:shortVersionString>0.7.3</sparkle:shortVersionString>
            <description><![CDATA[
                <h3>What's new</h3>
                <ul>
                    <li>Improves insertion into selected text fields on YouTube, Google Search, and other Chromium pages when the Accessibility tree is temporarily unavailable.</li>
                    <li>Enables the proven clean-install Codex fast path and in-payload boundary spacing by default, while retaining explicit rollback switches.</li>
                    <li>Keeps ChatGPT/Codex context-aware capitalization and spacing available through read-only Accessibility queries.</li>
                </ul>
            ]]></description>
            <pubDate>Sat, 18 Jul 2026 11:39:05 +0000</pubDate>
            <enclosure
                url="https://raw.githubusercontent.com/Solodnev/app-updates/main/dictationapp/Scribe-0.7.3.zip"
