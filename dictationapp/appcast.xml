        <item>
            <title>Version 0.6.0</title>
            <sparkle:version>13</sparkle:version>
            <sparkle:shortVersionString>0.6.0</sparkle:shortVersionString>
            <description><![CDATA[
                <h3>What's new</h3>
                <ul>
                    <li>Adopts Scribe as the official product name across the app and installer.</li>
                    <li>Adds the official black Scribe app icon.</li>
                    <li>Preserves existing sign-in sessions, permissions, and automatic updates through the rebrand.</li>
                </ul>
            ]]></description>
