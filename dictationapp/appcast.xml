        <item>
            <title>Version 0.5.1</title>
            <sparkle:version>10</sparkle:version>
            <sparkle:shortVersionString>0.5.1</sparkle:shortVersionString>
            <description><![CDATA[
                <h3>What's new</h3>
                <ul>
                    <li>Fixes first installation when the release ZIP is downloaded and extracted by Chrome or another standard ZIP tool.</li>
                    <li>Short dictations up to 5 seconds now use Friend ASR first, with Groq fallback for slow or unsuitable results.</li>
                    <li>Network latency diagnostics can detect and recover from a degraded upload connection.</li>
                </ul>
            ]]></description>
            <pubDate>Tue, 14 Jul 2026 20:15:07 +0000</pubDate>
